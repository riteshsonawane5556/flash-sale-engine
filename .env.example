# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_DB=0

# SQLite
DATABASE_URL=sqlite+aiosqlite:///./flash_sale.db

# Payment reservation window (milliseconds) — default 10 minutes
PAYMENT_TTL_MS=600000

# Distributed lock TTL (milliseconds)
LOCK_TTL_MS=5000

# Lock acquisition retries before giving up
LOCK_RETRY_ATTEMPTS=10

# Delay between lock retries (milliseconds)
LOCK_RETRY_DELAY_MS=100
